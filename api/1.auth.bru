meta {
  name: 1. Auth
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    bru.setVar("jwt_token", res.body.token);
  }
}
